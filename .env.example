# AI Sales Agent - Frontend Environment
# Copy this file to .env and fill in your values

# Firebase Configuration
# You can find these in the Firebase Console -> Project Settings -> General -> Your Apps -> Web App config
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=ai-sales-agent-27fbc.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ai-sales-agent-27fbc
VITE_FIREBASE_STORAGE_BUCKET=ai-sales-agent-27fbc.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
